// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DEVELOPER
  COMPANY
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  REMOTE
}

model User {
  id             Int      @id @default(autoincrement())
  name           String?
  email          String?  @unique
  emailVerified  DateTime?
  password       String?
  role           Role?
  image          String?
  createdAt      DateTime @default(now())

  // NextAuth relations
  accounts       Account[]


  // App relations
  developer      Developer?
  company        Company?
}

model Account {
  id                 Int      @id @default(autoincrement())
  userId             Int
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}



model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Developer {
  id           Int           @id @default(autoincrement())
  image        String?
  about        String?
  userId       Int           @unique

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]
}

model Company {
  id          Int     @id @default(autoincrement())
  name        String
  logo        String?
  description String?
  userId      Int     @unique

  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs        Job[]
}

model Job {
  id          Int           @id @default(autoincrement())
  title       String
  description String
  salary      Float?
  location    String
  type        JobType
  companyId   Int

  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[]
}

model Application {
  id           Int      @id @default(autoincrement())
  developerId  Int
  jobId        Int
  cvUrl        String
  message      String?
  createdAt    DateTime @default(now())

  developer    Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)
  job          Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([developerId, jobId])
}
